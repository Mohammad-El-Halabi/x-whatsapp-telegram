# Supabase public client configuration. Never place a service-role key in this app.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Telegram API application credentials used by the local Telethon runtime.
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# Optional development overrides. Production uses the bundled executable.
# TELEGRAM_SIDECAR_PATH=C:\path\to\telegram-sidecar.exe
# PYTHON_PATH=python
